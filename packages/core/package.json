{
  "name": "tabnyth-studio",
  "version": "0.1.0",
  "description": "Small local database studio for MongoDB and Postgres.",
  "type": "module",
  "bin": {
    "tabnyth-studio": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/types.d.ts",
      "default": "./dist/adapters/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:node && npm run build:ui",
    "build:node": "tsup src/index.ts src/adapters/types.ts src/cli/index.ts --format esm --dts --clean --external @tabnyth-studio/postgres --external @tabnyth-studio/mongodb",
    "build:ui": "vite build --config vite.config.ts",
    "dev": "vite --config vite.config.ts --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "cac": "^6.7.14",
    "hono": "^4.6.15"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.0",
    "@preact/preset-vite": "^2.9.1",
    "@testing-library/preact": "^3.2.4",
    "codemirror": "^6.0.1",
    "jsdom": "^25.0.1",
    "lucide-preact": "^1.21.0",
    "preact": "^10.25.3",
    "tsup": "^8.3.5",
    "vite": "^6.0.5"
  },
  "peerDependenciesMeta": {
    "@tabnyth-studio/mongodb": {
      "optional": true
    },
    "@tabnyth-studio/postgres": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.11"
  }
}
