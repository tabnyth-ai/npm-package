{
  "name": "tabnyth-workspace",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/postgres",
    "packages/mongodb"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w tabnyth",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=20.11"
  },
  "description": "Tabnyth Studio is a local-first database studio for Node developers. Install it as a dev dependency, point it at your database, and get a localhost web UI to browse tables, run guarded SQL or Mongo queries, search real data, edit cells, and visualize relationships. Writes are disabled by default.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tabnyth-ai/npm-package.git"
  },
  "keywords": [
    "aitool",
    "database"
  ],
  "author": "tabnyth-ai",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tabnyth-ai/npm-package/issues"
  },
  "homepage": "https://github.com/tabnyth-ai/npm-package#readme"
}
